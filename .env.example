# Copy to .env and fill in. Never commit the real .env.

# SQLite database file (relative to the prisma/ dir).
DATABASE_URL="file:./dev.db"

# HTTP port the API listens on (nginx proxies /api to this).
PORT=3001

# Comma-separated allowed CORS origins (the frontend).
CORS_ORIGINS="http://localhost:3000,https://jdesk.dev"

# Secret used to sign admin JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="12h"

# Seeded admin account (created by `npm run seed`).
ADMIN_EMAIL="admin@jdesk.dev"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="JDesk Admin"
