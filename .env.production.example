# Production backend env — copy to /var/www/jdesk/backend/.env on the VPS.
# NEVER commit the real .env. Generate a strong JWT_SECRET and a real password.

DATABASE_URL="file:./prod.db"
PORT=3001

# Only the public site origin(s). The SSR server calls the API internally.
CORS_ORIGINS="https://jdesk.dev,https://www.jdesk.dev"

# openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
JWT_EXPIRES_IN="12h"

# Seeded admin (change immediately after first login).
ADMIN_EMAIL="admin@jdesk.dev"
ADMIN_PASSWORD="REPLACE_WITH_A_STRONG_PASSWORD"
ADMIN_NAME="JDesk Admin"
